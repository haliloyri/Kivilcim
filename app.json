{
  "expo": {
    "name": "Spark",
    "slug": "spark",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "backgroundColor": "#131311",
    "icon": "./assets/spark_shortcut_logo.png",
    "splash": {
      "image": "./assets/spark_logo.png",
      "backgroundColor": "#FAF7F1",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.kivilcim.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSPhotoLibraryAddUsageDescription": "Spark, oluşturduğun paylaşım kartlarını galerine kaydetmek için izin ister."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/spark_shortcut_logo.png",
        "backgroundColor": "#131311"
      },
      "package": "com.kivilcim.app"
    },
    "plugins": [
      "expo-font",
      "expo-sqlite",
      "expo-asset",
      [
        "expo-media-library",
        {
          "photosPermission": "Spark, oluşturduğun paylaşım kartlarını galerine kaydetmek için izin ister.",
          "savePhotosPermission": "Spark, oluşturduğun paylaşım kartlarını galerine kaydetmek için izin ister.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3940256099942544~3347511713",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
          "skAdNetworkItems": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "73e8e4f4-f966-42cd-9c4e-3ffb9799314e"
      },
      "revenuecat": {
        "iosApiKey": "REPLACE_WITH_REVENUECAT_IOS_PUBLIC_SDK_KEY",
        "androidApiKey": "REPLACE_WITH_REVENUECAT_ANDROID_PUBLIC_SDK_KEY",
        "entitlementId": "premium",
        "offeringId": "default",
        "products": {
          "monthly": "spark_premium_monthly",
          "annual": "spark_premium_annual"
        }
      }
    },
    "owner": "hoyri"
  }
}
